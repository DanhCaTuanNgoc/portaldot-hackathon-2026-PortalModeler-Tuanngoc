OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Use Gemini API.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Use OpenRouter instead of the direct OpenAI API.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.2
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=PortalModeler
AI_MAX_OUTPUT_TOKENS=2048
